{
  "application_name": "PaymentAPI",
  "components": [
    {
      "name": "UserService",
      "description": "Handles user profiles and PII, sits behind the API gateway in the DMZ.",
      "trust_zone": "dmz"
    },
    {
      "name": "AuthService",
      "description": "External-facing authentication and session issuance.",
      "trust_zone": "external"
    },
    {
      "name": "PaymentService",
      "description": "Processes card payments in the DMZ.",
      "trust_zone": "dmz"
    },
    {
      "name": "InternalCache",
      "description": "Internal Redis cache, not reachable from outside.",
      "trust_zone": "internal"
    }
  ],
  "data_flows": [
    {
      "from": "UserService",
      "to": "Database",
      "data_types": ["PII", "credentials"],
      "crosses_trust_boundary": true
    },
    {
      "from": "AuthService",
      "to": "UserService",
