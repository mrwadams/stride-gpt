# .env.example
GITHUB_API_KEY=your_github_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OLLAMA_ENDPOINT=http://localhost:11434
LM_STUDIO_ENDPOINT=http://localhost:1234

# Optional. Host for the Streamlit diagram editor (embedded draw.io). Defaults
# to the public embed.diagrams.net. Point it at a self-hosted draw.io (scheme +
# host) for air-gapped/enterprise deployments; embed query params are appended.
# STRIDE_GPT_DRAWIO_URL=https://drawio.internal.example.com